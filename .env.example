# BLA — Variables d'environnement root (Docker Compose)
# Copier vers .env et remplir les valeurs

DB_PASSWORD=bla_local_password_change_me
REDIS_PASSWORD=bla_redis_password_change_me

# Générer les clés JWT :
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# cat private.pem | tr '\n' '\\n'
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Générer la clé de chiffrement :
# openssl rand -hex 32
ENCRYPTION_KEY=
